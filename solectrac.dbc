VAL_ 2566834890 Lamp_Malfunction 0 "off" 1 "on" 2 "reserved" 3 "n/a" ;
VAL_ 2566834890 Lamp_RedStop 0 "off" 1 "on" 2 "reserved" 3 "n/a" ;
VAL_ 2566834890 Lamp_AmberWarning 0 "off" 1 "on" 2 "reserved" 3 "n/a" ;
