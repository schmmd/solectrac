VAL_ 2566834890 DTC_FMI 0 "above_max" 1 "below_min" 2 "erratic" 3 "shorted_high" 4 "shorted_low" 5 "open_circuit" 6 "shorted_ground" 7 "wrong_response" 8 "abnormal_freq" 9 "abnormal_update" 10 "abnormal_change" 11 "unknown" 12 "bad_device" 13 "out_of_cal" 14 "special" 15 "info_high_least" 16 "info_high_mod" 17 "info_low_least" 18 "info_low_mod" 19 "data_error" 20 "drift_high" 21 "drift_low" 31 "condition_exists" ;
VAL_ 2566834890 DTC_CM 0 "modern" 1 "legacy" ;
VAL_ 2550588916 ChgrCmd_Enable 0 "active_request" 1 "idle" ;
